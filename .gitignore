# Raw data - not tracked, download separately (see README)
data/raw/*.csv
data/processed/*.csv

# Keep empty folder structure visible in git
!data/raw/.gitkeep
!data/processed/.gitkeep

# Database files
database/*.db
!database/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/

# Jupyter checkpoints
.ipynb_checkpoints/

# OS files
.DS_Store